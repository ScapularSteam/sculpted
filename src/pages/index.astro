---
import Default from "../templates/default.astro"
import Custombutton1 from "../components/custombutton1.astro"
---

<Default>
	<div class="flex flex-col w-screen h-screen items-center justify-center p-16">
		<div class="flex flex-col items-center justify-center h-2xl m-16 min-w-2xl   bg-coralmain shadow-2xl rounded-4xl border-16 border-coralaccent p-16">
			<img class="max-w-2xl w-screen" src="sculpted-logo.png"/>
			<p class="text-3xl font-itim pt-4">Sculpt keycaps, get light-up keyswitches or callipers!</p>
		</div>

		<div class="flex md:flex-row flex-col items-center justify-center">
			<Custombutton1 text="View the Guide" link="https://www.figma.com/deck/3T9mNZ1tCrWEvU2sMj8vqx/Sculpted-Workshop?node-id=1-42&viewport=-114%2C-135%2C0.69&t=ZBymVRbW2gF4vdeM-1&scaling=min-zoom&content-scaling=fixed&page-id=0%3A1"/>
			<Custombutton1 text="Submit your Project" link="example.org"/>
			<Custombutton1 text="Artwork and assets" link="https://www.figma.com/design/5ccbLXywSpTBA1iFVtM7jd/Sculpted?node-id=11-2&t=hFUMsR3tJ0M7BMk3-1"/>
		</div>
	</div>
</Default>